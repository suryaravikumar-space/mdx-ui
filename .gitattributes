# Normalize line endings to LF for source and content files so that
# Windows checkouts (core.autocrlf=true) don't introduce CRLF into
# YAML frontmatter, "use client" directives, etc.
* text=auto eol=lf

*.mdx text eol=lf
*.md text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files should never be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
