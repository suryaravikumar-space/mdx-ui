{
  // Vitest — covers packages/cli and packages/remark-plugin
  "vitest.workspaceConfig": "${workspaceFolder}/vitest.workspace.ts",
  "vitest.enable": true,

  // Jest — covers packages/registry (uses jest-environment-jsdom)
  "jest.jestCommandLine": "pnpm --filter @docsui/registry exec jest",
  "jest.rootPath": "${workspaceFolder}/packages/registry",
  "jest.autoRun": {
    "watch": false,
    "onStartup": ["all-tests"]
  },

  // TypeScript: use workspace version
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // Editor
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ESLint
  "eslint.workingDirectories": [
    { "directory": "packages/registry", "changeProcessCWD": true },
    { "directory": "packages/cli", "changeProcessCWD": true },
    { "directory": "packages/remark-plugin", "changeProcessCWD": true },
    { "directory": "apps/www", "changeProcessCWD": true }
  ],
  "eslint.validate": ["typescript", "typescriptreact"],

  // File excludes (keep workspace snappy)
  "files.exclude": {
    "**/node_modules": true,
    "**/.turbo": true,
    "**/dist": true,
    "**/.next": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/coverage": true
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  }
}
