{
  "name": "mdx-ui",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "suryaravikumar-space",
    "url": "https://github.com/suryaravikumar-space"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suryaravikumar-space/mdx-ui.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:registry": "tsx scripts/build-registry.ts",
    "www:dev": "pnpm --filter=@mdx-ui/www dev",
    "www:build": "pnpm --filter=@mdx-ui/www build",
    "cli:dev": "pnpm --filter=@mdx-ui/cli dev",
    "cli:build": "pnpm --filter=@mdx-ui/cli build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/www/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "eslint --config eslint.config.js --max-warnings=0 --fix",
      "prettier --write"
    ],
    "scripts/**/*.{ts,tsx}": [
      "eslint --config eslint.config.js --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.6",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.4.0",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "next": "^15.1.6",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7"
  }
}
