{
  "name": "docsui",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "suryaravikumar-space",
    "email": "suryaravikumar@docsui.io",
    "url": "https://github.com/suryaravikumar-space"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suryaravikumar-space/docsui.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "build:registry": "tsx scripts/build-registry.ts",
    "www:dev": "pnpm --filter=@docsui/www dev",
    "www:build": "pnpm --filter=@docsui/www build",
    "www:start": "pnpm --filter=@docsui/www start",
    "cli:dev": "pnpm --filter=docsui-cli dev",
    "cli:build": "pnpm --filter=docsui-cli build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,mdx}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "apps/www/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "eslint --config eslint.config.js --max-warnings=0 --fix",
      "prettier --write"
    ],
    "scripts/**/*.{ts,tsx}": [
      "eslint --config eslint.config.js --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,md,mdx,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.0.6",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.0.0",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.3",
    "next": "^15.1.6",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "next@>=15.0.0 <=15.4.4": ">=15.4.5 <16",
      "next@>=15.0.0-canary.0 <15.4.7": ">=15.4.7 <16",
      "next@>=10.0.0 <15.5.10": ">=15.5.10 <16",
      "next@>=15.5.1-canary.0 <15.5.10": ">=15.5.10 <16",
      "minimatch@<3.1.3": ">=3.1.3 <4",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@<3.1.4": ">=3.1.4 <4",
      "ajv@<6.14.0": ">=6.14.0 <7",
      "flatted@<3.4.0": ">=3.4.0",
      "next@>=9.5.0 <15.5.13": ">=15.5.13 <16",
      "next@>=10.0.0 <15.5.14": ">=15.5.14 <16",
      "flatted@<=3.4.1": ">=3.4.2",
      "brace-expansion@<1.1.13": ">=1.1.13 <2",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3 <3",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash-es@<=4.17.23": ">=4.18.0",
      "next@>=13.0.0 <15.5.15": ">=15.5.15 <16",
      "follow-redirects@<=1.15.11": ">=1.16.0",
      "dompurify@<=3.3.3": ">=3.4.0",
      "axios@>=1.0.0 <1.15.0": ">=1.15.0",
      "postcss@<8.5.10": ">=8.5.10",
      "dompurify@<3.4.0": ">=3.4.0",
      "dompurify@>=1.0.10 <3.4.0": ">=3.4.0",
      "dompurify@>=3.0.1 <3.4.0": ">=3.4.0",
      "protobufjs@<7.5.5": ">=7.5.5",
      "axios@>=1.0.0 <1.15.1": ">=1.15.1",
      "axios@>=1.0.0 <1.15.2": ">=1.15.2",
      "axios@>=1.0.0 <=1.13.4": ">=1.13.5",
      "next@>=13.0.0 <15.5.16": ">=15.5.16 <16",
      "mermaid@>=11.0.0-alpha.1 <=11.14.0": ">=11.15.0",
      "protobufjs@<=7.5.5": ">=7.5.6",
      "@protobufjs/utf8@<=1.1.0": ">=1.1.1",
      "next@>=15.2.0 <15.5.18": ">=15.5.18 <16",
      "next@>=12.2.0 <15.5.16": ">=15.5.16 <16",
      "next@>=13.4.0 <15.5.16": ">=15.5.16 <16",
      "next@>=13.4.6 <15.5.16": ">=15.5.16 <16",
      "next@>=15.0.0 <15.5.16": ">=15.5.16 <16",
      "next@>=10.0.0 <15.5.16": ">=15.5.16 <16",
      "next@>=13.4.13 <15.5.16": ">=15.5.16 <16",
      "next@>=15.4.0 <15.5.16": ">=15.5.16 <16",
      "next@>=14.2.0 <15.5.16": ">=15.5.16 <16",
      "next@>=15.2.0 <15.5.16": ">=15.5.16 <16",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "protobufjs@<=7.5.7": ">=7.5.8",
      "uuid@<11.1.1": ">=11.1.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "axios@>=1.0.0 <1.16.0": ">=1.16.0"
    }
  }
}
