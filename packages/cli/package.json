{
  "name": "@ravikumarsurya/mdx-ui",
  "version": "0.0.59",
  "description": "Transform LLM Markdown into rich, interactive UI components. Token-efficient bridge between any LLM and React — 50+ copy-paste MDX components, CLI, MCP server, and a remark plugin.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "suryaravikumar-space",
    "url": "https://github.com/suryaravikumar-space"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suryaravikumar-space/mdx-ui.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/suryaravikumar-space/mdx-ui#readme",
  "bugs": {
    "url": "https://github.com/suryaravikumar-space/mdx-ui/issues"
  },
  "keywords": [
    "mdx",
    "components",
    "documentation",
    "docs",
    "tailwindcss",
    "react",
    "shadcn",
    "cli",
    "llm",
    "ai",
    "markdown",
    "remark",
    "mcp",
    "callout",
    "tabs",
    "accordion",
    "code-block",
    "syntax-highlighting",
    "math",
    "katex",
    "mermaid",
    "data-structures",
    "nextjs",
    "astro"
  ],
  "exports": {
    ".": "./dist/index.js",
    "./metadata": "./dist/metadata.js",
    "./webview-bundle": "./dist/webview-bundle.js",
    "./save-mdx-page": "./dist/utils/save-mdx-page.js"
  },
  "bin": {
    "mdx-ui": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup && node scripts/build-webview-bundle.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --config ../../eslint.config.js --max-warnings=0 src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/glob": "^9.0.0",
    "axios": "^1.6.7",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.6",
    "ora": "^9.4.0",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.7",
    "esbuild": "^0.25.0",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
