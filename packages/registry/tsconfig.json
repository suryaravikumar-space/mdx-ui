{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@/lib/utils": ["./src/lib/utils"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/__tests__"]
}
