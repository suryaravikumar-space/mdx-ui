{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["jest", "@testing-library/jest-dom"],
    "paths": {
      "@/lib/utils": ["./src/lib/utils"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
