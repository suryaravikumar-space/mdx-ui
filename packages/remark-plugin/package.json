{
  "name": "@docsui-cli/remark-plugin",
  "version": "0.0.6",
  "description": "Remark plugin + string pre-processor — converts AI-generated markdown (blockquotes, tables, mermaid diagrams, numbered lists) to docsui components automatically",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "author": {
    "name": "suryaravikumar-space",
    "email": "suryaravikumar@docsui.io",
    "url": "https://github.com/suryaravikumar-space"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/suryaravikumar-space/docsui.git",
    "directory": "packages/remark-plugin"
  },
  "homepage": "https://github.com/suryaravikumar-space/docsui#readme",
  "keywords": [
    "remark",
    "mdx",
    "plugin",
    "docsui",
    "ai",
    "markdown",
    "callout",
    "datatable",
    "steps",
    "highlight",
    "mermaid",
    "diagram"
  ],
  "exports": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint --config ../../eslint.config.js --max-warnings=0 src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "unified": ">=10"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/unist": "^3.0.3",
    "tsup": "^8.0.2",
    "typescript": "^6.0.3",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.7"
  }
}
