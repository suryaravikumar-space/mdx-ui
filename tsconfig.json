{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "references": [{ "path": "./packages/remark-plugin" }],
  "exclude": [
    "node_modules",
    "apps",
    "packages",
    "dist",
    ".next",
    ".contentlayer"
  ]
}
